{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": ["framework", "laravel"],
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "aiz-packages/color-code-converter": "dev-main",
        "anandsiddharth/laravel-paytm-wallet": "^2.0",
        "bacon/bacon-qr-code": "^3.0",
        "barryvdh/laravel-ide-helper": "^2.13",
        "genealabs/laravel-sign-in-with-apple": "^12.0",
        "genealabs/laravel-socialiter": "^12.0",
        "guzzlehttp/guzzle": "^7.5",
        "instamojo/instamojo-php": "^0.4.0",
        "intervention/image": "^2.5",
        "kutia-software-company/larafirebase": "^1.3",
        "laracasts/flash": "^3.2",
        "laravel/framework": "^10.0",
        "laravel/reverb": "^1.0",
        "laravel/sanctum": "^3.2",
        "laravel/socialite": "^5.6",
        "laravel/tinker": "^2.8",
        "laravel/ui": "^4.2",
        "maatwebsite/excel": "^3.1",
        "mehedi-iitdu/core-component-repository": "^2.2",
        "niklasravnsborg/laravel-pdf": "^4.1",
        "paypal/paypal-checkout-sdk": "dev-master",
        "pusher/pusher-php-server": "^7.2",
        "razorpay/razorpay": "2.*",
        "spatie/db-dumper": "^3.3",
        "spatie/laravel-permission": "^5.5",
        "stripe/stripe-php": "^10.5",
        "unicodeveloper/laravel-paystack": "^1.0"
    },
    "require-dev": {
        "barryvdh/laravel-debugbar": "^3.8",
        "beyondcode/laravel-dump-server": "^1.0",
        "filp/whoops": "^2.0",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^7.0",
        "nunomaduro/larastan": "^2.9",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.0",
        "spatie/laravel-ignition": "^2.0"
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "symfony/thanks": true
        }
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-debugbar"
            ]
        }
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        },
        "classmap": [
            "database/seeds",
            "database/seeders",
            "database/factories"
        ],
        "files": [
            "app/Http/Helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ],
        "lint:php": [
            "git ls-files '*.php' ':!:vendor/*' ':!:storage/*' ':!:bootstrap/cache/*' | xargs -r -n 1 php -l"
        ],
        "format:check": [
            "pint --test"
        ],
        "analyse": [
            "phpstan analyse --memory-limit=1G"
        ],
        "test:backend": [
            "@php artisan test"
        ],
        "ci:backend": [
            "@composer validate --strict",
            "@composer lint:php",
            "@composer format:check",
            "@composer analyse",
            "@composer test:backend"
        ]
    }
}
